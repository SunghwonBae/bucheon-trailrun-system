// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 🏃 산악 마라톤(트레일 러닝) 선수 및 기록 모델
model TrailRunner {
  id          Int       @id @default(autoincrement())
  bibNumber   String    @unique // 배번
  name        String?           // 이름
  
  // 선수 정보
  phone       String?           // 폰번호
  gender      String?           // 남여구분
  birthYear   Int?              // 생년
  affiliation String?           // 소속
  note        String?           // 비고(기타사항)

  // 시간 기록
  startTime   DateTime?         // 출발 시간
  finishTime  DateTime?         // 도착 시간
  autoFinishTime  DateTime? // GPX로 측정된 자동 기록 (추가)

  paymentStatus   String    @default("N") // Y: 입금확인, N: 미입금, F: 무료
  printCount      Int       @default(0)   // 기록증 인쇄 횟수
  
  createdAt   DateTime  @default(now())

  @@map("trail_runners") // DB 테이블 이름을 trail_runners로 설정
}

// [추가] 대회 설정 관리 (년도별)
model RaceSetting {
  id            Int     @id @default(autoincrement())
  year          Int     @unique
  goalRadius    Int     @default(20)
  rankLimit     Int     @default(5)
  seniorYear    Int     // 청장년 구분 년도
  adminPw       String  @default("20260321")
  finishLineLat Float   @default(37.503)
  finishLineLng Float   @default(126.795)
  startTime     DateTime? // 대회 시작 시간
  finishTime    DateTime? // 대회 종료 시간
}

// 엄마가 미리 정의해두는 할 일 목록
model TodoMaster {
  id        Int      @id @default(autoincrement())
  title     String
  color     String   @default("#FFD700")
  isDeleted Boolean  @default(false) // 삭제 여부 (Soft Delete)
  duration  Int      @default(1)    // [추가] 기본 소요 시간 (1 = 30분, 2 = 1시간...)
  plans     TodoPlan[]
}

// 아이들이 시간표에 배치한 데이터
model TodoPlan {
  id           Int        @id @default(autoincrement())
  todoMasterId Int
  todoMaster   TodoMaster @relation(fields: [todoMasterId], references: [id])
  childName    String     // 하람, 움찬, 태랑
  planDate     String     // "2024-05-20"
  timeSlot     String     // "08:30"
  duration     Int        @default(1) // [추가] 1 = 30분, 2 = 1시간 ...
  isCompleted  Boolean    @default(false) // 엄마가 확인한 완료(별) 표시
}